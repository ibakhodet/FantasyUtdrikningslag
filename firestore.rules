rules_version = '2';

// Privat utdrikningslag-app for 7 venner. Kun innloggede kan lese,
// kun Martin (admin) kan skrive eventer og egne regler.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isMartin() {
      return isSignedIn() && request.auth.token.email == 'marteri9@gmail.com';
    }

    match /events/{doc} {
      allow read: if isSignedIn();
      allow create, update, delete: if isMartin();
    }

    match /teams/{doc} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /customRules/{doc} {
      allow read: if isSignedIn();
      allow create, update, delete: if isMartin();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
