rules_version = '2';

// Privat app for 7 venner. Autentisering håndterer tilgang.
// Admin-tilgang styres av PIN-kode i selve appen.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /events/{doc} {
      allow read, write: if isSignedIn();
    }

    match /teams/{doc} {
      allow read, write: if isSignedIn();
    }

    match /customRules/{doc} {
      allow read, write: if isSignedIn();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }
  }
}
